# Binance public market data API base URL (default: https://api.binance.com)
BINANCE_BASE_URL=https://api.binance.com

# Local SQLite database path (default: ./data/observer.db)
DB_PATH=./data/observer.db

# Logger level: error | warn | info | debug (default: info)
LOG_LEVEL=info

# Comma-separated Binance symbols to observe
MARKETS=BTCUSDT,CKBUSDT,XAUTUSDT,XAUUSDT

# Comma-separated Binance kline intervals to collect/analyze
INTERVALS=1m,5m,15m,1h,4h,1d

# Global gap between Binance requests in daemon mode
COLLECT_MIN_REQUEST_INTERVAL_MS=1200

# First-pass alert thresholds
ALERT_SHARP_MOVE_15M_PCT=1.5
ALERT_SHARP_MOVE_1H_PCT=3
ALERT_AGGREGATION_WINDOW_MS=180000
DIGEST_INTERVAL_HOURS=6

# Low-frequency market-structure sampling
STRUCTURE_MARKETS=BTCUSDT,ETHUSDT,SOLUSDT
STRUCTURE_INTERVAL_MS=300000
STRUCTURE_DEPTH_LIMIT=100
STRUCTURE_SLIPPAGE_NOTIONAL=10000

# Bark push notifications (optional)
BARK_BASE_URL=https://bark.example.com
BARK_DEVICE_KEY=replace-with-your-bark-device-key
BARK_GROUP=market-observer
BARK_LEVEL=active

# Gold cause monitor: Fed/rates/dollar headline attribution + GC=F 5m/15m move detector
GOLD_CAUSE_ENABLED=false
GOLD_SYMBOL=GC=F
GOLD_NEWS_QUERIES=gold Fed|gold Treasury yields|gold dollar|Fed Chair gold|XAUUSD Fed
GOLD_NEWS_LOOKBACK_MINUTES=240
GOLD_MOVE_5M_PCT=0.4
GOLD_MOVE_15M_PCT=0.8
GOLD_MONITOR_INTERVAL_MS=300000
